# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored — never commit secrets.
# All variables here are read by Vite at BUILD time; you'll need to
# restart `npm run dev` after editing.

# --- REQUIRED ---

# Solana mainnet RPC. Public api.mainnet-beta.solana.com is rate-limited;
# Helius / Triton / QuickNode are recommended for production traffic.
VITE_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=REPLACE_ME


# --- OPTIONAL ---

# DUST loyalty token mint. When set, the third output card unlocks in
# the picker. Leave empty until the token actually launches; the UI
# will still surface a "Coming Soon" placeholder card.
# VITE_SWEEP_MINT=

# Display-only USD reference for the DUST token before there's a Jupiter
# market for it. Pure UI hint; real swap math uses the live Jupiter
# quote response, never this number.
# VITE_SWEEP_USD_REF=0.10

# Wallet pubkey that owns the platform fee collector ATAs (one per
# output mint: USDC, WSOL, and SWEEP). The ATAs must exist on-chain
# before Duster can divert fees into them — Duster checks at build
# time and falls back to a fee-free sweep if the destination ATA is
# uninitialised.
# VITE_FEE_AUTHORITY=

# Cloudflare Web Analytics token, for the "Without Cloudflare proxy"
# mode. If duster.guru is already proxied through Cloudflare's CDN
# (orange-cloud DNS), CF collects analytics at the edge and this token
# is NOT needed. Only set this if you're hosting elsewhere.
# VITE_CF_ANALYTICS_TOKEN=
